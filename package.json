{
  "name": "indraanisa-pc-builder",
  "version": "2.6.24",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/bump-version.cjs",
    "build": "vite build",
    "build:full": "npm run prebuild && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "predownload:thumbnails": "node download-thumbnails.js",
    "deploy": "npm run build && gh-pages -d dist",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:full && electron-builder --win nsis --config electron-builder-config.json",
    "electron:pack": "npm run build && electron-packager . \"PCTG PC Builder\" --platform=win32 --arch=x64 --out=dist_electron_packager --overwrite",
    "master-update": "powershell -ExecutionPolicy Bypass -File master-update-dashboard.ps1",
    "master-update:electron": "electron electron/run-master-update.cjs",
    "master-update:direct": "node master-update-fast.js",
    "imgup": "node scripts/imgup.js",
    "imgup:once": "node scripts/imgup.js --once --force",
    "imgup:dashboard": "node scripts/imgup.js --dashboard-only",
    "imgup:help": "node scripts/imgup.js --help",
    "imgup:scheduled": "node scripts/imgup.js --scheduled --no-dashboard",
    "priceupd": "node scripts/priceupd.js",
    "priceupd:dashboard": "node scripts/priceupd.js --dashboard-only",
    "priceupd:help": "node scripts/priceupd.js --help",
    "schedule:tasks": "powershell -ExecutionPolicy Bypass -File scripts/schedule-aioupdate.ps1",
    "android:sync": "npm run build && npx cap sync",
    "android:open": "npx cap open android"
  },
  "build": {
    "appId": "com.indraanisa.pcbuilder",
    "productName": "PC Builder",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "C:\\Users\\simon\\WebstormProjects\\pctg_no_back_white_out_eA0_icon.ico"
    },
    "cscLink": null
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@google/genai": "^1.50.1",
    "@paypal/react-paypal-js": "^10.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "playwright": "^1.61.1",
    "puppeteer": "^25.3.0",
    "puppeteer-core": "^25.3.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "sharp": "^0.34.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "terser": "^5.46.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.5"
  }
}
