# Gemini API key — get yours from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Admin credentials for unlocking price/URL visibility
VITE_ADMIN_USER=your_admin_username
VITE_ADMIN_PASSWORD=your_admin_password_here

# Leonardo AI image generation proxy URL
VITE_LEONARDO_PROXY_URL=https://img-gen-pctg.vercel.app/api/generate

# EmailJS public key for contact form
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# PayPal Client ID (public, for JS SDK buttons)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# PayPal REST API credentials (server-side only, for invoicing)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_secret_here
PAYPAL_API_URL=https://api-m.paypal.com
PAYPAL_MERCHANT_EMAIL=your_paypal_merchant_email@example.com

# Firebase / Google Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id

# AdMob
VITE_ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# S3 Asset Bucket — source for prices, parts, images, CSVs, update.json
VITE_S3_ASSET_BUCKET=https://your-bucket.s3.region.amazonaws.com/

# Firebase Analytics endpoints
VITE_FIREBASE_ANALYTICS_URL=https://app-measurement.com/a
VITE_FIREBASE_ANALYTICS_SGTM_URL=https://app-measurement.com/s/d

# Google Advertising / Conversion Tracking
VITE_GOOGLE_CONVERSION_URL=https://www.googleadservices.com/pagead/conversion/app/deeplink?id_type=adid&sdk_version=%s&rdid=%s&bundleid=%s&retry=%s
VITE_GOOGLE_PAGEAD_URL=https://pagead2.googlesyndication.com/pagead/gen_204?id=gmob-apps

# Amazon Affiliate Base URLs (append ASIN to path)
VITE_AMAZON_US=https://www.amazon.com/dp/
VITE_AMAZON_UK=https://www.amazon.co.uk/dp/
VITE_AMAZON_DE=https://www.amazon.de/dp/
VITE_AMAZON_FR=https://www.amazon.fr/dp/
VITE_AMAZON_ES=https://www.amazon.es/dp/
VITE_AMAZON_IT=https://www.amazon.it/dp/
VITE_AMAZON_CA=https://www.amazon.ca/dp/
VITE_AMAZON_IN=https://www.amazon.in/dp/
VITE_AMAZON_AU=https://www.amazon.com.au/dp/

# Author link
VITE_AUTHOR_LINK=http://bit.ly/2BF4Qi9

# App Version
VITE_APP_VERSION=2.6.1

# Firecrawl API key — for scraping UK retailer prices
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Supabase for live pricing (components_prices table)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key for the Vercel cron function
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Pricing API keys (for api/update-prices.js)
VANTA_KEY=your_vantaspec_key_here
APIFY_KEY=your_apify_key_here
